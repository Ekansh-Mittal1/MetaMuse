# Do not commit large SQLite databases (GEOmetadb, pubmed, etc.) to Git — they are
# gitignored under data/ and built with `uv run setup-data` or pubmed_ingest.
# (Previously some paths used Git LFS; LFS objects were missing on the remote and
# broke clones — see README troubleshooting.)

# archs4_gsm_ids.txt (~10 MB) is stored as a normal Git blob (not LFS) so it
# always clones with the repo.

# Optional Git LFS for normalization FAISS indexes: remove
# ``src/normalization/semantic_indexes/`` from .gitignore before committing these paths.
# See src/normalization/README_INDEXES.md.
src/normalization/semantic_indexes/*.index filter=lfs diff=lfs merge=lfs -text
src/normalization/semantic_indexes/*.pkl filter=lfs diff=lfs merge=lfs -text
